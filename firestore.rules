rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'nikamvaishnavi82@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'wing', 'parentEmail', 'parentPhone', 'photoUrl', 'status'])
        && data.name is string && data.name.size() <= 100
        && data.wing is string && data.wing.size() <= 100
        && data.parentEmail is string && data.parentEmail.size() <= 100
        && data.parentPhone is string && data.parentPhone.size() <= 30
        && data.photoUrl is string && data.photoUrl.size() <= 1000000
        && (!('userId' in data) || data.userId == null || data.userId == request.auth.uid);
    }

    function isValidAttendanceLog(data) {
      return data.keys().hasAll(['studentId', 'busId', 'action', 'timestamp', 'location'])
        && data.studentId is string && isValidId(data.studentId)
        && data.busId is string && isValidId(data.busId)
        && data.action in ['board', 'exit']
        && data.timestamp == request.time;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['studentId', 'recipientEmail', 'message', 'type', 'timestamp', 'sent'])
        && data.studentId is string && isValidId(data.studentId)
        && data.recipientEmail is string && data.recipientEmail.size() <= 100
        && data.type in ['boarding', 'exiting']
        && data.timestamp == request.time;
    }

    // --- Collection Routes ---

    match /admins/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false; 
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidStudent(incoming());
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid) && isValidStudent(incoming());
      allow delete: if isSignedIn();
    }

    match /buses/{busId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSignedIn(); // Relaxed for seeding
    }

    match /attendance_logs/{logId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidAttendanceLog(incoming()) && exists(/databases/$(database)/documents/students/$(incoming().studentId));
      allow delete: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.recipientEmail == request.auth.token.email);
      allow get: if isSignedIn() && (isAdmin() || resource.data.recipientEmail == request.auth.token.email);
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow delete: if isSignedIn();
    }
  }
}